# ============================================================
# YOURPARTY.TECH V2 ENVIRONMENT CONFIGURATION
# Copy to .env and fill with production values
# ============================================================

# ========== MYSQL (WordPress) ==========
MYSQL_ROOT_PASSWORD=change_me_mysql_root
WP_DB_NAME=yourparty
WP_DB_USER=yourparty
WP_DB_PASSWORD=change_me_wp_db
WP_DEBUG=false

# ========== POSTGRESQL (Directus) ==========
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=change_me_directus_db
DIRECTUS_DB_NAME=directus

# ========== DIRECTUS ==========
# Generate these with: openssl rand -base64 32
DIRECTUS_KEY=generate-with-openssl-rand-base64-32
DIRECTUS_SECRET=generate-with-openssl-rand-base64-32
DIRECTUS_ADMIN_EMAIL=admin@yourparty.tech
DIRECTUS_ADMIN_PASSWORD=change_me_admin
# Static token for backend-to-Directus API calls
DIRECTUS_STATIC_TOKEN=

# ========== REDIS ==========
REDIS_PASSWORD=change_me_redis

# ========== MEILISEARCH ==========
# Generate with: openssl rand -base64 32
MEILI_MASTER_KEY=generate-with-openssl-rand-base64-32

# ========== MONGODB (Legacy - Migration Only) ==========
MONGO_USER=admin
MONGO_PASSWORD=change_me_mongo

# ========== AZURACAST ==========
AZURACAST_URL=https://radio.yourparty.tech
AZURACAST_API_KEY=your_azuracast_api_key
AZURACAST_VERIFY_SSL=true

# ========== BEETS / METADATA SERVICES ==========
# Leave blank - Wolfi will fill before docker-compose up
DISCOGS_USER_TOKEN=
MUSICBRAINZ_USER=

# ========== PATHS ==========
# Inbox: Where new uploads go (watched by Beets)
INBOX_PATH=/mnt/nas/yourparty/inbox
# Library: Curated music (output from Beets)
LIBRARY_PATH=/mnt/nas/yourparty/library
# Legacy music path (read-only for migration)
MUSIC_PATH=/mnt/nas/yourparty_Libary

# SSL Certificates
SSL_CERT_PATH=/etc/ssl/certs
SSL_KEY_PATH=/etc/ssl/private

# ========== FEATURE FLAGS ==========
# Enable V2 services (set to true after migration)
FEATURE_V2_DIRECTUS=false
FEATURE_V2_REDIS=false
# Existing features
FEATURE_MOOD_VOTES=true
FEATURE_MOOD_AUTODJ=true
MOOD_CYCLE_SECONDS=300
