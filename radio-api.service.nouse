[Unit]
Description=Radio API Service
After=network.target

[Service]
User=radio-api
Group=radio-api
WorkingDirectory=/opt/radio-api
EnvironmentFile=/opt/radio-api/.env
ExecStart=/opt/radio-api/venv/bin/uvicorn api:app --host 0.0.0.0 --port 8000 --proxy-headers --forwarded-allow-ips '*'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
