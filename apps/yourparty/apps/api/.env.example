# YourParty.tech API Configuration
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control!

# MongoDB Connection
MONGO_URI=mongodb://user:password@hostname:27017/?authSource=admin

# AzuraCast API
AZURACAST_API_URL=https://radio.yourparty.tech/api
AZURACAST_API_KEY=your_api_key_here
AZURACAST_STATION_ID=1
AZURACAST_VERIFY_SSL=true

# Music Assistant (Home Assistant)
MASS_TOKEN=your_ha_token_here
MASS_URL=http://192.168.x.x:8123

# NAS / File Server (SMB)
SMB_SERVER=192.168.x.x
SMB_SHARE=music
SMB_USERNAME=user
SMB_PASSWORD=password

# Library Paths
LIBRARY_SUBDIR=yourparty_Libary
LIBRARY_ROOT_WIN=Z:\yourparty_Libary
LIBRARY_ROOT_LINUX=/var/radio/music/yourparty_Libary
