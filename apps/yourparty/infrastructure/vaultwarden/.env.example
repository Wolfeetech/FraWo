VAULTWARDEN_DOMAIN=https://vault.yourparty.tech
VAULTWARDEN_ADMIN_TOKEN=replace-with-strong-random
TZ=Europe/Berlin

# Email for invites + 2FA backup codes
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=security@yourparty.tech
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=smtp-pass
SMTP_SECURITY=starttls

# Optional anti-abuse
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=false
SHOW_PASSWORD_HINT=false
