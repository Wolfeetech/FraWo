# YourParty.tech Environment Configuration
# Copy this file to .env and adjust values for your environment

# AzuraCast API
AZURACAST_BASE_URL=https://radio.yourparty.tech
AZURACAST_STATION_ID=1
AZURACAST_API_KEY=your_api_key_here

# FastAPI Backend (Mood/Rating Service)
FASTAPI_URL=http://192.168.178.211:8000

# MongoDB (used by FastAPI)
MONGODB_URI=mongodb://192.168.178.202:27017/yourparty

# WebSocket (optional - has polling fallback)
WEBSOCKET_URL=wss://radio.yourparty.tech/ws/radio.yourparty

# Feature Flags
FEATURE_MOOD_AUTODJ=false
MOOD_CYCLE_SECONDS=300
