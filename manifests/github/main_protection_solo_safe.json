{
  "repository": "Wolfeetech/FraWo",
  "branch": "main",
  "mode": "solo-safe",
  "applied_at": "2026-04-22",
  "auth_mode": "temporary GH_TOKEN from Git Credential Manager",
  "verified": {
    "allow_force_pushes": false,
    "allow_deletions": false,
    "required_conversation_resolution": true
  },
  "intended_effect": [
    "disable force pushes",
    "disable branch deletion",
    "require conversation resolution when pull requests are used",
    "keep direct maintainer commits possible for small SSOT updates"
  ],
  "apply_command": "powershell -ExecutionPolicy Bypass -File scripts\\github\\configure_main_protection.ps1",
  "strict_mode_command": "powershell -ExecutionPolicy Bypass -File scripts\\github\\configure_main_protection.ps1 -StrictPullRequestMode",
  "requires": [
    "GitHub CLI installed",
    "Git Credential Manager credential or gh auth login"
  ]
}
