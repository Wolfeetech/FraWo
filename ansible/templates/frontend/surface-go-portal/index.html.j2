<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <title>FRAWO Control</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@200;400;600;800&display=swap');

    :root {
      --bg: linear-gradient(135deg, #0a0a1a 0%, #10102a 60%, #1a0a2a 100%);
      --glass: rgba(255,255,255,0.05);
      --border: rgba(255,255,255,0.1);
      --text: #f1f5f9;
      --muted: #8899aa;
      --indigo: #6366f1;
      --pink: #ec4899;
      --green: #22c55e;
      --red: #ef4444;
      --amber: #f59e0b;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow: hidden;
      user-select: none;
      -webkit-user-select: none;
      -webkit-tap-highlight-color: transparent;
    }

    /* --- Ambient blobs --- */
    .blob { position: fixed; border-radius: 50%; filter: blur(100px); z-index: 0; pointer-events: none; animation: drift 25s infinite ease-in-out alternate; }
    .b1 { width: 500px; height: 500px; background: rgba(99,102,241,0.3); top: -150px; left: -150px; }
    .b2 { width: 600px; height: 600px; background: rgba(236,72,153,0.25); bottom: -200px; right: -150px; animation-delay: -7s; }
    @keyframes drift { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(40px,40px) scale(1.15); } }

    /* --- Layout --- */
    #app {
      position: relative; z-index: 1;
      height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 0;
      padding: 1rem;
    }

    /* --- Header --- */
    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.25rem;
      animation: fadeUp .7s ease both;
    }

    .brand { font-size: 1.6rem; font-weight: 800; letter-spacing: -1px;
      background: linear-gradient(90deg, #fff 30%, #a5b4fc);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }

    .header-right { display: flex; align-items: center; gap: 1.5rem; }

    #clock { font-size: 1.8rem; font-weight: 200; color: var(--muted); letter-spacing: 1px; }

    .sys-pill {
      display: flex; align-items: center; gap: .5rem;
      background: var(--glass); border: 1px solid var(--border);
      border-radius: 999px; padding: .45rem 1rem;
      font-size: .85rem; color: var(--muted);
      backdrop-filter: blur(12px);
    }
    .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px var(--green); flex-shrink: 0; }
    .dot.warn { background: var(--amber); box-shadow: 0 0 8px var(--amber); }
    .dot.err  { background: var(--red);   box-shadow: 0 0 8px var(--red); }

    /* --- Main grid --- */
    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
      gap: 0.8rem;
      height: 100%;
    }

    /* --- Cards --- */
    .card {
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 1rem;
      display: flex; flex-direction: column;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      transition: transform .25s, border-color .25s, box-shadow .25s;
      animation: fadeUp .8s ease both;
      overflow: hidden;
    }
    .card:active { transform: scale(0.98); }
    .card:active { transform: scale(0.98); }

    .card-label {
      font-size: .72rem; font-weight: 600; letter-spacing: .1em;
      text-transform: uppercase; color: var(--muted); margin-bottom: .5rem;
    }

    /* --- Radio card (spans 2 rows) --- */
    #card-radio { grid-column: 1; grid-row: 1 / 3;
      background: linear-gradient(160deg, rgba(99,102,241,.18) 0%, rgba(168,85,247,.18) 100%);
      border-color: rgba(168,85,247,.3);
    }

    .now-playing-art {
      width: 100%; max-height: 40vh; aspect-ratio: 1; border-radius: 14px; object-fit: contain;
      background: rgba(255,255,255,.05); margin-bottom: .6rem;
      box-shadow: 0 6px 16px rgba(0,0,0,.4);
    }

    .np-artist { font-size: .9rem; color: var(--muted); margin-bottom: .2rem; }
    .np-title { font-size: 1.3rem; font-weight: 700; line-height: 1.2; margin-bottom: .3rem; word-break: break-word; }
    .np-album { font-size: .8rem; color: var(--muted); margin-bottom: .8rem; }

    .np-progress { height: 4px; border-radius: 2px; background: rgba(255,255,255,.12); margin-bottom: .9rem; }
    .np-bar { height: 100%; border-radius: 2px; background: linear-gradient(90deg, var(--indigo), var(--pink)); transition: width 1s linear; }

    .radio-controls { display: flex; gap: .75rem; justify-content: center; }
    .ctrl-btn {
      flex: 1; height: 50px; border-radius: 12px; border: 1px solid var(--border);
      background: rgba(255,255,255,.08); color: var(--text);
      font-size: 1.4rem; cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: background .2s, transform .1s;
    }
    .ctrl-btn:active { transform: scale(.93); background: rgba(255,255,255,.18); }
    .ctrl-btn.primary-btn {
      background: linear-gradient(135deg, var(--indigo), var(--pink));
      border-color: transparent; font-size: 1.8rem;
    }
    .ctrl-btn:active { transform: scale(.93); background: rgba(255,255,255,.18); }
    .ctrl-btn.primary-btn {
      background: linear-gradient(135deg, var(--indigo), var(--pink));
      border-color: transparent; font-size: 2rem;
    }

    .np-next { font-size: .8rem; color: var(--muted); margin-top: .6rem; }
    .np-next strong { color: var(--text); }

    /* --- Presence card --- */
    #card-presence { grid-column: 2; grid-row: 1; }

    .presence-list { display: grid; gap: .6rem; margin-top: .5rem; }
    .presence-item {
      display: flex; align-items: center; gap: .75rem;
      background: rgba(255,255,255,.04); border-radius: 12px; padding: .6rem .9rem;
    }
    .presence-avatar {
      width: 38px; height: 38px; border-radius: 50%;
      background: linear-gradient(135deg, var(--indigo), var(--pink));
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 1rem; flex-shrink: 0;
    }
    .presence-info { flex: 1; }
    .presence-name { font-weight: 600; font-size: .95rem; }
    .presence-detail { font-size: .78rem; color: var(--muted); }
    .presence-badge {
      font-size: .72rem; font-weight: 600; padding: .2rem .55rem; border-radius: 999px;
      background: rgba(34,197,94,.15); color: var(--green); border: 1px solid rgba(34,197,94,.3);
    }
    .presence-badge.away { background: rgba(245,158,11,.12); color: var(--amber); border-color: rgba(245,158,11,.3); }
    .presence-badge.offline { background: rgba(100,100,120,.12); color: var(--muted); border-color: rgba(100,100,120,.3); }

    /* --- System card --- */
    #card-system { grid-column: 3; grid-row: 1; }

    .service-row {
      display: flex; align-items: center; gap: .65rem;
      padding: .45rem 0; border-bottom: 1px solid var(--border);
    }
    .service-row:last-child { border-bottom: none; }
    .service-name { flex: 1; font-size: .9rem; }
    .service-status { font-size: .8rem; color: var(--muted); }

    /* --- Voice card --- */
    #card-voice { grid-column: 2; grid-row: 2; }

    .voice-area {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 1rem; text-align: center;
    }

    #voice-btn {
      width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--border);
      background: var(--glass); cursor: pointer;
      font-size: 2.2rem; display: flex; align-items: center; justify-content: center;
      transition: all .2s; color: var(--text);
    }
    #voice-btn.active {
      background: linear-gradient(135deg, var(--indigo), var(--pink));
      border-color: transparent;
      box-shadow: 0 0 30px rgba(99,102,241,.6);
      animation: pulse 1s infinite;
    }
    @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.08); } }

    #voice-transcript {
      font-size: .9rem; color: var(--muted); min-height: 2.5rem;
      line-height: 1.4; max-width: 220px;
    }
    #voice-result {
      font-size: .82rem; color: var(--indigo); font-weight: 600; min-height: 1.2rem;
    }

    /* --- Actions card --- */
    #card-actions { grid-column: 3; grid-row: 2; }

    .action-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .7rem; flex: 1; }
    .action-btn {
      border-radius: 16px; border: 1px solid var(--border);
      background: var(--glass); color: var(--text);
      cursor: pointer; padding: 1rem .5rem;
      display: flex; flex-direction: column; align-items: center; gap: .35rem;
      font-family: 'Outfit', sans-serif;
      font-size: .82rem; font-weight: 600;
      transition: background .2s, transform .1s;
      text-decoration: none;
    }
    .action-btn:active { transform: scale(.95); background: rgba(255,255,255,.12); }
    .action-btn .icon { font-size: 1.8rem; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

    /* --- Mobile Adapt --- */
    @media (max-width: 900px) {
      .grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
      gap: 0.8rem;
      height: 100%;
    }
      #card-radio { grid-column: 1 / 3; grid-row: auto; }
      #card-presence, #card-system, #card-voice, #card-actions { grid-column: auto; grid-row: auto; }
    }
    @media (max-width: 600px) {
      .grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
      gap: 0.8rem;
      height: 100%;
    }
      #card-radio { grid-column: 1; }
      #app {
      position: relative; z-index: 1;
      height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 0;
      padding: 1rem;
    }
      .brand { font-size: 1.6rem; font-weight: 800; letter-spacing: -1px;
      background: linear-gradient(90deg, #fff 30%, #a5b4fc);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    }
  </style>
</head>
<body>
  <div class="blob b1"></div>
  <div class="blob b2"></div>

  <div id="app">
    <header>
      <span class="brand">FRAWO Control</span>
      <div class="header-right">
        <div id="clock">00:00</div>
        <div class="sys-pill"><span class="dot" id="sys-dot"></span><span id="sys-text">System</span></div>
      </div>
    </header>

    <div class="grid">

      <!-- RADIO CARD -->
      <div class="card" id="card-radio">
        <div class="card-label">📻 Live Radio</div>
        <img class="now-playing-art" id="np-art" src="" alt="Cover">
        <div class="np-artist" id="np-artist">Wird geladen...</div>
        <div class="np-title" id="np-title">–</div>
        <div class="np-album" id="np-album"></div>
        <div class="np-progress"><div class="np-bar" id="np-progress-bar" style="width:0%"></div></div>
        <div class="radio-controls">
          <button class="ctrl-btn" id="btn-listen" title="Play/Pause" onclick="toggleRadio()">▶️</button>
          <button class="ctrl-btn primary-btn" id="btn-skip" title="Song überspringen">⏭</button>
          <button class="ctrl-btn" title="Radio Control" onclick="window.location='http://radio.hs27.internal/login'">🎛️</button>
        </div>
        <div class="np-next" id="np-next"></div>
      </div>

      <!-- PRESENCE CARD -->
      <div class="card" id="card-presence">
        <div class="card-label">📡 Geräte & Personen</div>
        <div class="presence-list" id="presence-list">
          <div class="presence-item">
            <div class="presence-avatar">W</div>
            <div class="presence-info">
              <div class="presence-name">Wolf</div>
              <div class="presence-detail" id="wolf-detail">Wird abgefragt...</div>
            </div>
            <span class="presence-badge" id="wolf-badge">...</span>
          </div>
          <div class="presence-item">
            <div class="presence-avatar" style="background: linear-gradient(135deg,#ec4899,#f43f5e)">F</div>
            <div class="presence-info">
              <div class="presence-name">Franz</div>
              <div class="presence-detail" id="franz-detail">Unbekannt</div>
            </div>
            <span class="presence-badge offline" id="franz-badge">–</span>
          </div>
          <div class="presence-item">
            <div class="presence-avatar" style="background: linear-gradient(135deg,#0ea5e9,#6366f1); font-size:.75rem">PI</div>
            <div class="presence-info">
              <div class="presence-name">Radio Node</div>
              <div class="presence-detail" id="pi-detail">radio-node</div>
            </div>
            <span class="presence-badge" id="pi-badge">...</span>
          </div>
        </div>
      </div>

      <!-- SYSTEM STATUS CARD -->
      <div class="card" id="card-system">
        <div class="card-label">⚡ Dienste</div>
        <div id="service-list" style="display:flex;flex-direction:column;flex:1;justify-content:center;">
          <div class="service-row">
            <span class="dot" id="d-ha"></span>
            <span class="service-name">Home Assistant</span>
            <span class="service-status" id="s-ha">...</span>
          </div>
          <div class="service-row">
            <span class="dot" id="d-cloud"></span>
            <span class="service-name">Nextcloud</span>
            <span class="service-status" id="s-cloud">...</span>
          </div>
          <div class="service-row">
            <span class="dot" id="d-media"></span>
            <span class="service-name">Jellyfin</span>
            <span class="service-status" id="s-media">...</span>
          </div>
          <div class="service-row">
            <span class="dot" id="d-radio"></span>
            <span class="service-name">Radio</span>
            <span class="service-status" id="s-radio">...</span>
          </div>
          <div class="service-row">
            <span class="dot" id="d-odoo"></span>
            <span class="service-name">Odoo</span>
            <span class="service-status" id="s-odoo">...</span>
          </div>
          <div class="service-row">
            <span class="dot" id="d-paper"></span>
            <span class="service-name">Paperless</span>
            <span class="service-status" id="s-paper">...</span>
          </div>
        </div>
      </div>

      
      <!-- NAVBAR / HELP CARD -->
      <div class="card" id="card-voice">
        <div class="card-label">🧭 Navigation</div>
        <div class="voice-area" style="font-size: 0.95rem; color: var(--text);">
          <p style="margin-bottom:0.8rem;"><b>Zurückgehen:</b> Wische vom <i>linken Bildschirmrand</i> zur Mitte, um zurückzukehren.</p>
          <button onclick="window.location.reload()" style="padding: 0.6rem 1rem; border-radius: 12px; border: 1px solid var(--border); background: var(--glass); color: white; width: 100%; font-size: 1rem; cursor: pointer;">Dashboard Refresh 🔄</button>
        </div>
      </div>


      <!-- ACTIONS CARD -->
      <div class="card" id="card-actions">
        <div class="card-label">⚡ Direktaktionen</div>
        <div class="action-grid">
          <a href="http://ha.hs27.internal" class="action-btn">
            <span class="icon">🏠</span>Smart Home
          </a>
          <a href="http://media.hs27.internal" class="action-btn">
            <span class="icon">🎬</span>Medien
          </a>
          <a href="http://cloud.hs27.internal" class="action-btn">
            <span class="icon">☁️</span>Nextcloud
          </a>
          <a href="http://paperless.hs27.internal" class="action-btn">
            <span class="icon">📄</span>Dokumente
          </a>
        </div>
      </div>

    </div><!-- /grid -->
  </div><!-- /app -->

  <script>
    const RADIO_API = 'http://radio.hs27.internal/api/nowplaying/frawo-funk';
    const STATUS_API = 'http://portal.hs27.internal/status.json';
    const SKIP_API = 'http://radio.hs27.internal/api/station/frawo-funk/backend/skip';

    // ─── Clock ───────────────────────────────────────────────
    function tick() {
      document.getElementById('clock').textContent =
        new Date().toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
    }
    setInterval(tick, 1000); tick();

    
    // --- Embedded Radio Player ---
    const streamUrl = 'http://radio.hs27.internal/listen/frawo-funk/radio.mp3';
    let player = new Audio();
    let isPlaying = false;

    function toggleRadio() {
      const btn = document.getElementById('btn-listen');
      if (isPlaying) {
        player.pause();
        player.src = '';
        isPlaying = false;
        btn.textContent = '▶️';
      } else {
        player.src = streamUrl;
        player.play().catch(e => console.error(e));
        isPlaying = true;
        btn.textContent = '⏸️';
      }
    }


    // ─── Radio Now Playing ────────────────────────────────────
    let npDuration = 1, npElapsed = 0, npTimer;

    async function updateRadio() {
      try {
        const r = await fetch(RADIO_API, { cache: 'no-store' });
        const d = await r.json();
        const np = d.now_playing;
        const song = np.song;

        document.getElementById('np-art').src = song.art || '';
        document.getElementById('np-artist').textContent = song.artist || '–';
        document.getElementById('np-title').textContent = song.title || song.text || '–';
        document.getElementById('np-album').textContent = song.album || '';

        npDuration = np.duration || 1;
        npElapsed = np.elapsed || 0;

        const next = d.playing_next;
        if (next && next.song) {
          document.getElementById('np-next').innerHTML =
            `Nächster Titel: <strong>${next.song.artist || ''} – ${next.song.title || next.song.text || ''}</strong>`;
        }

        // Auto-advance progress locally
        clearInterval(npTimer);
        npTimer = setInterval(() => {
          npElapsed++;
          const pct = Math.min(100, (npElapsed / npDuration) * 100);
          document.getElementById('np-progress-bar').style.width = pct + '%';
        }, 1000);

        // Presence: radio node alive
        document.getElementById('pi-detail').textContent = d.station.name + ' • live';
        setPresence('pi-badge', 'Online');

      } catch(e) {
        document.getElementById('np-title').textContent = 'Fehler beim Laden';
      }
    }
    setInterval(updateRadio, 15000); updateRadio();

    // ─── Skip Button ──────────────────────────────────────────
    document.getElementById('btn-skip').onclick = async () => {
      const btn = document.getElementById('btn-skip');
      btn.textContent = '⌛';
      try {
        // AzuraCast backend skip – requires API key; falls back to graceful NOOP
        await fetch(SKIP_API, { method: 'POST', headers: { 'X-API-Key': '' } });
        btn.textContent = '✅';
        setTimeout(() => { btn.textContent = '⏭'; updateRadio(); }, 1500);
      } catch(e) {
        btn.textContent = '⏭';
        // Fallback: navigate to control panel
        window.open('http://radio.hs27.internal/login', '_blank');
      }
    };

    // ─── System Status ────────────────────────────────────────
    const serviceMap = [
      { key: 'homeassistant', dot: 'd-ha',    stat: 's-ha',    label: 'ha.hs27.internal' },
      { key: 'nextcloud',     dot: 'd-cloud', stat: 's-cloud', label: 'cloud.hs27.internal' },
      { key: 'jellyfin',      dot: 'd-media', stat: 's-media', label: 'media.hs27.internal' },
      { key: 'azuracast',     dot: 'd-radio', stat: 's-radio', label: 'radio.hs27.internal' },
      { key: 'odoo',          dot: 'd-odoo',  stat: 's-odoo',  label: 'odoo.hs27.internal' },
      { key: 'paperless',     dot: 'd-paper', stat: 's-paper', label: 'paperless.hs27.internal' },
    ];

    async function updateSystemStatus() {
      try {
        const r = await fetch(STATUS_API, { cache: 'no-store' });
        const d = await r.json();

        const sysDot = document.getElementById('sys-dot');
        const items = Array.isArray(d.services) ? d.services : [];

        serviceMap.forEach(svc => {
          const found = items.find(i => i.key === svc.key || i.label === svc.label || (i.label && i.label.toLowerCase().includes(svc.key)));
          const ok = found ? found.status === 'ok' : null;
          const dotEl = document.getElementById(svc.dot);
          const statEl = document.getElementById(svc.stat);
          if (dotEl) { dotEl.className = 'dot' + (ok === false ? ' err' : ok === null ? ' warn' : ''); }
          if (statEl) { statEl.textContent = ok === false ? 'Fehler' : ok === null ? '?' : 'OK'; }
        });

        const healthy = d.healthy_services ?? 0, total = d.total_services ?? 0;
        if (healthy >= total) {
          sysDot.className = 'dot';
          document.getElementById('sys-text').textContent = `${healthy}/${total} Dienste OK`;
        } else {
          sysDot.className = 'dot warn';
          document.getElementById('sys-text').textContent = `${healthy}/${total} gesund`;
        }

      } catch(e) {
        document.getElementById('sys-dot').className = 'dot err';
        document.getElementById('sys-text').textContent = 'System offline';
      }
    }
    setInterval(updateSystemStatus, 30000); updateSystemStatus();

    // ─── Presence (Tailscale via ping) ────────────────────────
    // Since we can't run tailscale CLI in a browser, we probe devices
    const devices = [
      { ip: '100.76.249.126', id: 'wolf', name: 'Wolf', label: 'ZenBook', badge: 'wolf-badge', detail: 'wolf-detail' },
      { ip: '100.64.23.77',   id: 'pi',   name: 'Pi',   label: 'Radio Node', badge: 'pi-badge', detail: 'pi-detail' },
    ];

    function setPresence(badgeId, text, type) {
      const el = document.getElementById(badgeId);
      if (!el) return;
      el.textContent = text;
      el.className = 'presence-badge' + (type === 'away' ? ' away' : type === 'offline' ? ' offline' : '');
    }

    async function probeDevice(dev) {
      try {
        const ctrl = new AbortController();
        const tid = setTimeout(() => ctrl.abort(), 2000);
        const r = await fetch(`http://${dev.ip}:17827`, { signal: ctrl.signal, mode: 'no-cors', cache: 'no-store' });
        clearTimeout(tid);
        setPresence(dev.badge, 'Online', null);
        document.getElementById(dev.detail).textContent = dev.label + ' • erreichbar';
      } catch(e) {
        if (e.name === 'AbortError') {
          setPresence(dev.badge, 'Keine Antwort', 'away');
          document.getElementById(dev.detail).textContent = dev.label + ' • Timeout';
        } else {
          // net::ERR_CONNECTION_REFUSED still means device is up
          setPresence(dev.badge, 'Online', null);
          document.getElementById(dev.detail).textContent = dev.label + ' • im Tailnet';
        }
      }
    }

    // Wolf on ZenBook: probe 100.76.249.126, Franz device unknown – show as dynamic greeting
    async function updatePresence() {
      await probeDevice(devices[0]);
      const wolfBadge = document.getElementById('wolf-badge').textContent;
      document.getElementById('wolf-detail').textContent =
        wolfBadge === 'Online' ? 'ZenBook • im Netz' : 'ZenBook • nicht erreichbar';
      setPresence('franz-badge', 'Unbekannt', 'offline');
      document.getElementById('franz-detail').textContent = 'Kein Gerät konfiguriert';
    }
    setInterval(updatePresence, 20000); updatePresence();

    // ─── Voice Control ────────────────────────────────────────
    let recognition = null, voiceActive = false;
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;

    function processVoiceCommand(text) {
      const cmd = text.toLowerCase().trim();
      const res = document.getElementById('voice-result');
      if (cmd.includes('skip') || cmd.includes('weiter') || cmd.includes('nächst')) {
        res.textContent = '⏭ Song wird übersprungen...';
        document.getElementById('btn-skip').click();
      } else if (cmd.includes('home') || cmd.includes('smart')) {
        res.textContent = '🏠 Home Assistant wird geöffnet...';
        setTimeout(() => window.location = 'http://ha.hs27.internal', 800);
      } else if (cmd.includes('radio') || cmd.includes('musik')) {
        res.textContent = '📻 Radio Player wird geöffnet...';
        setTimeout(() => window.location = 'http://radio.hs27.internal/public/frawo-funk', 800);
      } else if (cmd.includes('medien') || cmd.includes('film') || cmd.includes('jellyfin')) {
        res.textContent = '🎬 Jellyfin wird geöffnet...';
        setTimeout(() => window.location = 'http://media.hs27.internal', 800);
      } else {
        res.textContent = `❓ "${text}" – nicht erkannt`;
        setTimeout(() => res.textContent = '', 3000);
      }
    }

    function toggleVoice() {
      if (!SR) {
        document.getElementById('voice-transcript').textContent = 'Spracherkennung nicht unterstützt';
        return;
      }
      if (voiceActive) {
        recognition && recognition.stop();
        voiceActive = false;
        document.getElementById('voice-btn').className = '';
        document.getElementById('voice-btn').textContent = '🎙️';
        return;
      }
      recognition = new SR();
      recognition.lang = 'de-DE';
      recognition.interimResults = true;
      recognition.continuous = false;
      recognition.onstart = () => {
        voiceActive = true;
        document.getElementById('voice-btn').className = 'active';
        document.getElementById('voice-btn').textContent = '🔴';
        document.getElementById('voice-transcript').textContent = 'Höre zu...';
        document.getElementById('voice-result').textContent = '';
      };
      recognition.onresult = e => {
        const t = Array.from(e.results).map(r => r[0].transcript).join('');
        document.getElementById('voice-transcript').textContent = `"${t}"`;
        if (e.results[e.results.length-1].isFinal) processVoiceCommand(t);
      };
      recognition.onend = () => {
        voiceActive = false;
        document.getElementById('voice-btn').className = '';
        document.getElementById('voice-btn').textContent = '🎙️';
      };
      recognition.start();
    }
  </script>
</body>
</html>
