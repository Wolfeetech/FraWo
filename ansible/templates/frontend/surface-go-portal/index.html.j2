<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
    <title>OpenClaw Control Center 3.1</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #020204;
            --sidebar-bg: rgba(8, 8, 12, 0.8);
            --accent: #00e5ff;
            --accent-glow: rgba(0, 229, 255, 0.4);
            --secondary: #ff00ea;
            --success: #00ffa2;
            --error: #ff4d4d;
            --text-main: #f0f0f5;
            --text-muted: #888899;
            --font-heading: 'Outfit', sans-serif;
            --font-body: 'Inter', sans-serif;
            --card-bg: rgba(20, 20, 25, 0.6);
            --border: rgba(255, 255, 255, 0.08);
            --touch-target: 64px;
            --glass: blur(25px) saturate(180%);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            user-select: none;
        }

        body {
            background: radial-gradient(circle at 50% -20%, #1a1a2e 0%, var(--bg) 70%);
            color: var(--text-main);
            font-family: var(--font-body);
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            display: flex;
        }

        /* Sidebar Glassmorphism */
        .sidebar {
            width: 110px;
            background: var(--sidebar-bg);
            backdrop-filter: var(--glass);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 30px 0;
            z-index: 1000;
        }

        .nav-item {
            width: 76px;
            height: 76px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 25px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
            color: var(--text-muted);
            border: 1px solid transparent;
            background: rgba(255, 255, 255, 0.02);
        }

        .nav-item:active {
            transform: scale(0.88);
            background: rgba(0, 229, 255, 0.15);
        }

        .nav-item.active, .nav-item:hover {
            color: var(--accent);
            border-color: var(--accent-glow);
            box-shadow: 0 0 25px var(--accent-glow);
            background: rgba(0, 229, 255, 0.08);
        }

        .nav-item.home-btn {
            background: linear-gradient(145deg, var(--accent), #00aaff);
            color: #000;
            margin-bottom: 45px;
            box-shadow: 0 10px 20px rgba(0, 229, 255, 0.3);
        }

        .nav-spacer { flex: 1; }

        /* Main Stage */
        .stage {
            flex: 1;
            position: relative;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        header {
            height: 90px;
            padding: 0 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            background: rgba(2, 2, 4, 0.6);
            backdrop-filter: var(--glass);
        }

        .logo {
            font-family: var(--font-heading);
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: 4px;
            text-transform: uppercase;
        }

        .logo span { 
            color: var(--accent);
            text-shadow: 0 0 15px var(--accent-glow);
        }

        .system-status {
            display: flex;
            gap: 30px;
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .status-pill {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255, 255, 255, 0.03);
            padding: 10px 20px;
            border-radius: 30px;
            border: 1px solid var(--border);
            transition: all 0.3s;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--error);
            box-shadow: 0 0 10px var(--error);
        }

        .dot.online { 
            background: var(--success); 
            box-shadow: 0 0 12px var(--success); 
            animation: pulse-success 2s infinite;
        }

        @keyframes pulse-success {
            0% { box-shadow: 0 0 8px var(--success); }
            50% { box-shadow: 0 0 18px var(--success); }
            100% { box-shadow: 0 0 8px var(--success); }
        }

        /* View Container */
        .view-container {
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            display: grid;
            grid-template-columns: 1fr 450px;
            gap: 50px;
        }

        /* Dashboard Grid - Premium Cards */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            align-content: start;
        }

        .service-card {
            background: var(--card-bg);
            backdrop-filter: blur(15px);
            border: 1px solid var(--border);
            border-radius: 32px;
            padding: 40px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            display: flex;
            flex-direction: column;
            gap: 18px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .service-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 100%);
            pointer-events: none;
        }

        .service-card:active {
            transform: translateY(-5px) scale(1.02);
            border-color: var(--accent);
            background: rgba(0, 229, 255, 0.1);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .service-icon { 
            font-size: 3.5rem; 
            margin-bottom: 10px;
            filter: drop-shadow(0 10px 15px rgba(0,0,0,0.3));
        }
        .service-name { 
            font-family: var(--font-heading); 
            font-size: 1.5rem; 
            font-weight: 700; 
            letter-spacing: 0.5px;
        }
        .service-desc { 
            color: var(--text-muted); 
            font-size: 0.95rem; 
            line-height: 1.4;
        }

        /* AI Chat Panel - Professional */
        .chat-panel {
            background: rgba(15, 15, 20, 0.4);
            backdrop-filter: var(--glass);
            border: 1px solid var(--border);
            border-radius: 40px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            height: calc(100vh - 190px);
            box-shadow: 0 30px 60px rgba(0,0,0,0.6);
        }

        .chat-header {
            padding: 25px 35px;
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid var(--border);
            font-weight: 700;
            font-family: var(--font-heading);
            letter-spacing: 2px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .chat-header::before {
            content: '';
            width: 12px; height: 12px;
            background: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--accent);
        }

        .chat-messages {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
            scrollbar-width: none;
        }
        .chat-messages::-webkit-scrollbar { display: none; }

        .msg {
            padding: 18px 24px;
            border-radius: 24px;
            font-size: 1.05rem;
            max-width: 85%;
            line-height: 1.6;
            animation: fadeIn 0.4s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .msg.user { 
            background: linear-gradient(135deg, var(--accent), #0099ff); 
            color: #000; 
            align-self: flex-end; 
            font-weight: 600;
            border-bottom-right-radius: 4px;
        }
        .msg.bot { 
            background: rgba(255, 255, 255, 0.05); 
            border: 1px solid var(--border); 
            align-self: flex-start; 
            border-bottom-left-radius: 4px;
        }

        .chat-input-area {
            padding: 30px;
            background: rgba(0, 0, 0, 0.2);
            border-top: 1px solid var(--border);
            display: flex;
            gap: 20px;
        }

        .chat-input {
            flex: 1;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 20px 25px;
            color: #fff;
            font-size: 1.1rem;
            outline: none;
            transition: all 0.3s;
        }

        .chat-input:focus { 
            border-color: var(--accent); 
            background: rgba(255, 255, 255, 0.05);
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.1);
        }

        /* Iframe Layer */
        .iframe-layer {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #000;
            z-index: 5000;
            display: none;
        }

        .iframe-layer iframe { width: 100%; height: 100%; border: none; }

        /* Floating Nav for Iframe */
        .floating-nav {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 20px;
            z-index: 6000;
            padding: 15px 30px;
            background: rgba(10, 10, 15, 0.85);
            backdrop-filter: blur(15px);
            border-radius: 40px;
            border: 1px solid var(--accent);
            box-shadow: 0 10px 40px rgba(0,0,0,0.8);
        }

        .f-btn {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            border: 1px solid var(--border);
            transition: all 0.2s;
        }

        .f-btn:active { transform: scale(0.85); background: var(--accent); color: #000; }

        .f-btn.home { background: var(--accent); color: #000; }

        /* Loading Overlay */
        #loader {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 20px;
        }

        .spinner {
            width: 60px; height: 60px;
            border: 5px solid var(--border);
            border-top: 5px solid var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

    </style>
</head>
<body>
    <div id="loader"><div class="spinner"></div><div style="font-weight:bold; letter-spacing:2px;">LOADING SERVICE...</div></div>

    <nav class="sidebar">
        <div class="nav-item home-btn active" onclick="showDashboard()">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        </div>
        <div class="nav-item" onclick="toggleChat()">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        </div>
        <div class="nav-spacer"></div>
        <div class="nav-item" onclick="window.location.reload()">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
        </div>
    </nav>

    <div class="stage">
        <header>
            <div class="logo">OPEN<span>CLAW</span> 3.1</div>
            <div class="system-status">
                <div class="status-pill"><div class="dot online" id="s-brain"></div> STUDIO</div>
                <div class="status-pill"><div class="dot online" id="s-cloud"></div> CLOUD</div>
                <div id="clock" style="font-size: 1.4rem; font-weight: 700; color: var(--accent);">00:00</div>
            </div>
        </header>

        <div class="view-container" id="main-view">
            <div class="dashboard-grid">
                {% for action in surface_go_actions_manifest.actions %}
                {% if action.status == 'ready' %}
                <div class="service-card" onclick="openService('{{ action.target_url }}')">
                    <div class="service-icon">
                        {% if action.group == 'Dokumente' %}☁️
                        {% elif action.group == 'Odoo' %}💼
                        {% elif action.group == 'Radio' %}📻
                        {% elif action.group == 'Stockenweiler' %}🏠
                        {% else %}🚀{% endif %}
                    </div>
                    <div class="service-name">{{ action.label }}</div>
                    <div class="service-desc">{{ action.group }}</div>
                </div>
                {% endif %}
                {% endfor %}
            </div>
            </div>

            <div class="chat-panel" id="chat-panel">
                <div class="chat-header">🦞 OPENCLAW AGENT</div>
                <div class="chat-messages" id="chat-msgs">
                    <div class="msg bot">Bereit. Wie kann ich die RTX-Power heute nutzen?</div>
                </div>
                <div class="chat-input-area">
                    <input type="text" class="chat-input" id="chat-in" placeholder="Nachricht..." onkeypress="handleChat(event)">
                    <button class="nav-item" style="width:60px; height:60px; margin:0;" onclick="sendChat()">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                    </button>
                </div>
            </div>
        </div>

        <div class="iframe-layer" id="iframe-layer">
            <div class="floating-nav">
                <div class="f-btn" onclick="iframeBack()" title="Zurück">
                    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </div>
                <div class="f-btn home" onclick="showDashboard()" title="Home">
                    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
                </div>
                <div class="f-btn" onclick="iframeReload()" title="Reload">
                    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                </div>
            </div>
            <iframe id="main-frame" src=""></iframe>
        </div>
    </div>

    <script>
        const API_BASE = "http://100.98.31.60:5555";

        function updateClock() {
            const now = new Date();
            document.getElementById('clock').textContent = now.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
        }
        setInterval(updateClock, 1000);
        updateClock();

        function openService(url) {
            const layer = document.getElementById('iframe-layer');
            const iframe = document.getElementById('main-frame');
            iframe.src = url;
            layer.style.display = 'block';
            document.getElementById('main-view').style.filter = 'blur(10px)';
            document.getElementById('loader').style.display = 'flex';
            
            iframe.onload = () => {
                document.getElementById('loader').style.display = 'none';
            };
        }

        function showDashboard() {
            const layer = document.getElementById('iframe-layer');
            layer.style.display = 'none';
            document.getElementById('main-view').style.filter = 'none';
            document.getElementById('main-frame').src = '';
        }

        function iframeBack() {
            const iframe = document.getElementById('main-frame');
            try {
                iframe.contentWindow.history.back();
            } catch(e) {
                console.error("Cannot go back across origins");
            }
        }

        function iframeReload() {
            const iframe = document.getElementById('main-frame');
            iframe.src = iframe.src;
        }

        function toggleChat() {
            const panel = document.getElementById('chat-panel');
            panel.style.display = panel.style.display === 'none' ? 'flex' : 'none';
        }

        async function sendChat() {
            const input = document.getElementById('chat-in');
            const msg = input.value.trim();
            if (!msg) return;

            appendMsg('user', msg);
            input.value = '';

            try {
                const res = await fetch(`${API_BASE}/api/chat`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg })
                });
                const data = await res.json();
                appendMsg('bot', data.response || "Agent antwortet nicht.");
            } catch (e) {
                appendMsg('bot', "Fehler: Verbindung zum StudioPC fehlgeschlagen.");
            }
        }

        function handleChat(e) { if (e.key === 'Enter') sendChat(); }

        function appendMsg(role, text) {
            const chat = document.getElementById('chat-msgs');
            const div = document.createElement('div');
            div.className = `msg ${role}`;
            div.textContent = text;
            chat.appendChild(div);
            chat.scrollTop = chat.scrollHeight;
        }

        async function refreshSystem() {
            try {
                const res = await fetch(`${API_BASE}/api/status`);
                const data = await res.json();
                console.log("System Status:", data);
                
                const brainDot = document.getElementById('s-brain');
                if (data.status === 'online') {
                    brainDot.classList.add('online');
                } else {
                    brainDot.classList.remove('online');
                }
            } catch (e) { 
                console.error("Status fetch failed"); 
                document.getElementById('s-brain').classList.remove('online');
            }
        }

        // Initial check and periodic refresh
        refreshSystem();
        setInterval(refreshSystem, 30000);

        // Prevent context menu
        document.addEventListener('contextmenu', e => e.preventDefault());
    </script>
</body>
</html>
