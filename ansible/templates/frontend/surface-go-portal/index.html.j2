<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <title>FraWo Control</title>
  <style>
    :root {
      --bg: #0b1320;
      --bg-alt: #101a2b;
      --panel: rgba(12, 23, 38, 0.92);
      --panel-soft: rgba(17, 31, 49, 0.86);
      --border: rgba(146, 166, 193, 0.18);
      --text: #f4f7fb;
      --muted: #97a7bc;
      --accent: #5aa8ff;
      --accent-soft: rgba(90, 168, 255, 0.16);
      --ok: #56c288;
      --shadow: 0 24px 60px rgba(1, 8, 18, 0.42);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      font-family: "Segoe UI", system-ui, -apple-system, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(90, 168, 255, 0.14), transparent 32%),
        radial-gradient(circle at bottom right, rgba(53, 99, 173, 0.18), transparent 40%),
        linear-gradient(180deg, var(--bg) 0%, #09111b 100%);
      color: var(--text);
      user-select: none;
      -webkit-user-select: none;
      -webkit-tap-highlight-color: transparent;
    }

    .shell {
      min-height: 100vh;
      padding: 1rem;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 1rem;
    }

    .topbar,
    .footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.4rem 0.75rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.04);
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .eyebrow::before {
      content: "";
      width: 0.55rem;
      height: 0.55rem;
      border-radius: 50%;
      background: var(--ok);
      box-shadow: 0 0 10px rgba(86, 194, 136, 0.8);
    }

    .hero {
      display: grid;
      gap: 0.45rem;
    }

    .hero h1 {
      font-size: clamp(1.9rem, 4vw, 2.8rem);
      line-height: 1.02;
      letter-spacing: -0.04em;
    }

    .hero p {
      max-width: 38rem;
      color: var(--muted);
      font-size: 0.98rem;
      line-height: 1.45;
    }

    .clock {
      min-width: 5.5rem;
      text-align: right;
      font-size: 1.7rem;
      font-weight: 300;
      letter-spacing: 0.04em;
      color: var(--muted);
    }

    .groups {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      align-content: start;
    }

    .group-card {
      display: grid;
      grid-template-rows: auto auto 1fr;
      gap: 0.85rem;
      padding: 1rem;
      border-radius: 1.2rem;
      border: 1px solid var(--border);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 24%),
        var(--panel);
      box-shadow: var(--shadow);
    }

    .group-card h2 {
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .group-card p {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.4;
    }

    .group-actions {
      display: grid;
      gap: 0.8rem;
      align-content: start;
    }

    .action-card {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 0.8rem;
      align-items: start;
      padding: 0.9rem;
      border-radius: 1rem;
      border: 1px solid rgba(146, 166, 193, 0.16);
      background: var(--panel-soft);
      color: inherit;
      text-decoration: none;
      transition: transform 0.12s ease, border-color 0.12s ease, background 0.12s ease;
    }

    .action-card:active {
      transform: scale(0.98);
      border-color: rgba(90, 168, 255, 0.45);
      background: rgba(18, 37, 61, 0.96);
    }

    .action-code {
      min-width: 2.6rem;
      min-height: 2.6rem;
      padding: 0.35rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 0.85rem;
      background: var(--accent-soft);
      color: var(--accent);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .action-copy {
      display: grid;
      gap: 0.22rem;
      min-width: 0;
    }

    .action-label {
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .action-note {
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.35;
    }

    .action-meta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.28rem 0.55rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .footer {
      padding-top: 0.15rem;
      border-top: 1px solid rgba(146, 166, 193, 0.12);
    }

    .footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }

    .footer-links a,
    .footer-links button {
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.03);
      color: var(--muted);
      text-decoration: none;
      padding: 0.5rem 0.85rem;
      font: inherit;
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
    }

    .footer-note {
      color: var(--muted);
      font-size: 0.78rem;
      text-align: right;
    }

    @media (max-width: 980px) {
      .groups {
        grid-template-columns: 1fr;
      }

      .group-actions {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .shell {
        padding: 0.85rem;
      }

      .topbar,
      .footer {
        grid-template-columns: 1fr;
        align-items: start;
      }

      .topbar,
      .footer {
        display: grid;
      }

      .clock,
      .footer-note {
        text-align: left;
      }

      .group-actions {
        grid-template-columns: 1fr;
      }

      .action-card {
        grid-template-columns: auto 1fr;
      }

      .action-meta {
        grid-column: 2;
        justify-self: start;
      }
    }
  </style>
</head>
<body>
  {% set all_actions = surface_go_actions_manifest.actions | default([]) %}
  {% set ready_actions = all_actions | selectattr('status', 'equalto', 'ready') | list %}
  {% set groups = [
    {'id': 'Dokumente', 'title': 'Dokumente', 'subtitle': 'Eingang und Archiv ohne Zusatzballast.'},
    {'id': 'Odoo', 'title': 'Odoo', 'subtitle': 'Aufgaben, Projekte und Kalender ohne Umwege.'},
    {'id': 'Radio', 'title': 'Radio', 'subtitle': 'Player und Steuerung fuer den internen Radiopfad.'}
  ] %}
  {% set action_meta = {
    'nextcloud_inbox': {'code': 'NC', 'note': 'Eingangsordner direkt'},
    'paperless_archive': {'code': 'PL', 'note': 'Archiv direkt'},
    'odoo_tasks': {'code': 'OD', 'note': 'Taskboard direkt'},
    'odoo_projects': {'code': 'OD', 'note': 'Projektboard direkt'},
    'odoo_calendar': {'code': 'OD', 'note': 'Kalender direkt'},
    'radio_listen': {'code': 'RA', 'note': 'FraWo-Funk direkt hoeren'},
    'radio_control': {'code': 'RC', 'note': 'AzuraCast Bedienung'}
  } %}

  <div class="shell">
    <header class="topbar">
      <div class="hero">
        <span class="eyebrow">Interne Aktionen</span>
        <h1>FraWo Control</h1>
        <p>Dokumente, Odoo und Radio als echte Aktionskonsole. Kein Dashboard, keine Statusprosa, keine Fake-Knöpfe.</p>
      </div>
      <div class="clock" id="clock">00:00</div>
    </header>

    <main class="groups" aria-label="Surface Control V1">
      {% for group in groups %}
      {% set group_actions = ready_actions | selectattr('group', 'equalto', group.id) | list %}
      {% if group_actions %}
      <section class="group-card" aria-labelledby="group-{{ loop.index }}">
        <div>
          <span class="eyebrow">{{ group.title }}</span>
        </div>
        <div>
          <h2 id="group-{{ loop.index }}">{{ group.title }}</h2>
          <p>{{ group.subtitle }}</p>
        </div>
        <div class="group-actions">
          {% for action in group_actions %}
          {% set meta = action_meta.get(action.id, {'code': 'GO', 'note': action.target_kind | replace('_', ' ')}) %}
          <a class="action-card" href="{{ action.target_url }}">
            <span class="action-code">{{ meta.code }}</span>
            <span class="action-copy">
              <span class="action-label">{{ action.label }}</span>
              <span class="action-note">{{ meta.note }}</span>
            </span>
            <span class="action-meta">
              {% if action.requires_login %}Login{% else %}Direkt{% endif %}
            </span>
          </a>
          {% endfor %}
        </div>
      </section>
      {% endif %}
      {% endfor %}
    </main>

    <footer class="footer">
      <div class="footer-links">
        <a href="http://portal.hs27.internal">Portal</a>
        <a href="http://portal.hs27.internal/franz/">Franz</a>
        <button type="button" onclick="window.location.reload()">Neu laden</button>
      </div>
      <div class="footer-note">Website public bleibt bewusst im Hold. Surface zeigt nur den internen Arbeitskern.</div>
    </footer>
  </div>

  <script>
    function updateClock() {
      const now = new Date();
      document.getElementById("clock").textContent = now.toLocaleTimeString("de-DE", {
        hour: "2-digit",
        minute: "2-digit"
      });
    }

    updateClock();
    setInterval(updateClock, 1000);
  </script>
</body>
</html>
