#!/usr/bin/env python3
import json
import subprocess
from datetime import datetime, timezone
from pathlib import Path

STATUS_FILE = Path("/opt/homeserver2027/stacks/toolbox-network/portal/status.json")
STATUS_FILE.parent.mkdir(parents=True, exist_ok=True)
MEDIA_SYNC_TARGET = Path("{{ toolbox_media_radio_sync_target_path }}")
MEDIA_SYNC_LOG = Path("{{ toolbox_media_radio_sync_log_path }}")

targets = [
{% for item in toolbox_network_status_targets %}
    {
        "key": "{{ item.key }}",
        "label": "{{ item.label }}",
        "check_url": "{{ item.check_url }}",
        "success_codes": {{ item.success_codes | to_json }},
        "summary": "{{ item.summary }}",
    },
{% endfor %}
]


def http_code(url: str) -> str:
    result = subprocess.run(
        [
            "curl",
            "--silent",
            "--show-error",
            "--location",
            "--max-time",
            "8",
            "--output",
            "/dev/null",
            "--write-out",
            "%{http_code}",
            url,
        ],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return "000"
    return result.stdout.strip() or "000"


def command_output(command: list[str]) -> str:
    result = subprocess.run(
        command,
        capture_output=True,
        text=True,
        check=False,
    )
    return result.stdout.strip()


def directory_file_count(path: Path) -> int:
    if not path.exists():
        return 0
    return sum(1 for item in path.rglob("*") if item.is_file())


def directory_size_human(path: Path) -> str:
    if not path.exists():
        return "0B"
    raw = command_output(["du", "-sh", str(path)])
    if not raw:
        return "0B"
    return raw.split()[0]


def sync_state() -> str:
    return "retired"


def timer_state() -> str:
    return "retired"


def last_sync_line() -> str:
    return "Local bootstrap sync retired; central SMB library is canonical"


services = []
healthy = 0
for target in targets:
    code = http_code(target["check_url"])
    is_ok = code.isdigit() and int(code) in target["success_codes"]
    if is_ok:
        healthy += 1
    services.append(
        {
            "key": target["key"],
            "label": target["label"],
            "summary": target["summary"],
            "check_url": target["check_url"],
            "http_code": code,
            "status": "ok" if is_ok else "attention",
        }
    )

payload = {
    "generated_at": datetime.now(timezone.utc).isoformat(),
    "healthy_services": healthy,
    "total_services": len(services),
    "platform_core": "ok" if healthy == len(services) else "attention",
    "media_sync": {
        "state": sync_state(),
        "timer_state": timer_state(),
        "target_file_count": directory_file_count(MEDIA_SYNC_TARGET),
        "target_size": directory_size_human(MEDIA_SYNC_TARGET),
        "last_log_line": last_sync_line(),
    },
    "services": services,
}

STATUS_FILE.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
