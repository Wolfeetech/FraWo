#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '[haos-runner] %s\n' "$*"
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    log "Missing required command: $1"
    exit 1
  fi
}

for cmd in curl python3 qm unxz; do
  require_cmd "$cmd"
done

VMID="{{ proxmox_haos_vmid }}"
VM_NAME="{{ proxmox_haos_name }}"
VM_STORAGE="{{ proxmox_haos_storage }}"
VM_BRIDGE="{{ proxmox_haos_bridge }}"
VM_MACHINE="{{ proxmox_haos_machine }}"
VM_BIOS="{{ proxmox_haos_bios }}"
VM_CPU="{{ proxmox_haos_cpu }}"
VM_CORES="{{ proxmox_haos_cores }}"
VM_MEMORY_MB="{{ proxmox_haos_memory_mb }}"
VM_DISK_GB="{{ proxmox_haos_disk_gb }}"
VM_AGENT_ENABLED="{{ proxmox_haos_agent_enabled }}"
VM_ONBOOT="{{ proxmox_haos_onboot }}"
VM_PROTECTION="{{ proxmox_haos_protection }}"
VM_FIREWALL="{{ proxmox_haos_firewall }}"
VM_START_AFTER_CREATE="{{ 1 if proxmox_haos_start_after_create else 0 }}"
IMG_DIR="{{ proxmox_haos_image_dir }}"

if qm status "$VMID" >/dev/null 2>&1; then
  log "VM ${VMID} already exists; leaving the current VM untouched."
  qm config "$VMID"
  exit 0
fi

mkdir -p "$IMG_DIR"

HAOS_TAG="${HAOS_TAG_OVERRIDE:-}"
if [[ -z "$HAOS_TAG" ]]; then
  log "Resolving latest Home Assistant OS release tag"
  HAOS_TAG="$(
    curl -fsSL "https://api.github.com/repos/home-assistant/operating-system/releases/latest" \
    | python3 -c 'import json, sys; print(json.load(sys.stdin)["tag_name"])'
  )"
fi

HAOS_FILE="haos_ova-${HAOS_TAG}.qcow2.xz"
HAOS_URL="https://github.com/home-assistant/operating-system/releases/download/${HAOS_TAG}/${HAOS_FILE}"
HAOS_COMPRESSED_PATH="${IMG_DIR}/${HAOS_FILE}"
HAOS_IMAGE_PATH="${IMG_DIR}/haos_ova-${HAOS_TAG}.qcow2"

if [[ ! -f "$HAOS_IMAGE_PATH" ]]; then
  if [[ ! -f "$HAOS_COMPRESSED_PATH" ]]; then
    log "Downloading ${HAOS_URL}"
    curl -fL "$HAOS_URL" -o "$HAOS_COMPRESSED_PATH"
  else
    log "Using cached archive ${HAOS_COMPRESSED_PATH}"
  fi

  log "Decompressing ${HAOS_COMPRESSED_PATH}"
  unxz -f "$HAOS_COMPRESSED_PATH"
else
  log "Using cached image ${HAOS_IMAGE_PATH}"
fi

log "Creating VM ${VMID} (${VM_NAME})"
qm create "$VMID" \
  --name "$VM_NAME" \
  --ostype l26 \
  --machine "$VM_MACHINE" \
  --bios "$VM_BIOS" \
  --cpu "$VM_CPU" \
  --cores "$VM_CORES" \
  --memory "$VM_MEMORY_MB" \
  --scsihw virtio-scsi-single \
  --net0 "virtio,bridge=${VM_BRIDGE},firewall=${VM_FIREWALL}" \
  --serial0 socket \
  --vga serial0 \
  --agent "enabled=${VM_AGENT_ENABLED}" \
  --onboot "$VM_ONBOOT" \
  --protection "$VM_PROTECTION"

log "Importing Home Assistant OS disk into ${VM_STORAGE}"
qm importdisk "$VMID" "$HAOS_IMAGE_PATH" "$VM_STORAGE"

IMPORTED_DISK="$(qm config "$VMID" | awk -F': ' '/^unused[0-9]+:/ {print $2; exit}')"
if [[ -z "$IMPORTED_DISK" ]]; then
  log "Could not determine imported disk for VM ${VMID}"
  exit 1
fi

log "Attaching imported disk and finalizing firmware settings"
qm set "$VMID" --scsi0 "${IMPORTED_DISK},discard=on,ssd=1,iothread=1"
qm set "$VMID" --boot order=scsi0
qm set "$VMID" --efidisk0 "${VM_STORAGE}:0,efitype=4m,pre-enrolled-keys=0"
qm set "$VMID" --rng0 source=/dev/urandom
qm resize "$VMID" scsi0 "${VM_DISK_GB}G"

if [[ "$VM_START_AFTER_CREATE" == "1" ]]; then
  log "Starting VM ${VMID}"
  qm start "$VMID"
else
  log "Leaving VM ${VMID} stopped by configuration"
fi

log "HAOS VM runner completed successfully"
