version: '3'
services:
  db:
    image: mariadb:10.11
    command: --transaction-isolation=READ-COMMITTED --binlog-format=ROW
    restart: always
    env_file:
      - stack.env
    volumes:
      - db:/var/lib/mysql

  redis:
    image: redis:alpine
    restart: always

  app:
    image: nextcloud:apache
    restart: always
    ports:
      - "{{ compose_http_port }}:80"
    env_file:
      - stack.env
    volumes:
      - nextcloud:/var/www/html
    depends_on:
      - db
      - redis

volumes:
  nextcloud:
  db:
