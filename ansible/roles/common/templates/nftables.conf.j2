#!/usr/sbin/nft -f
# /etc/nftables.conf – managed by Ansible role 'common'
# MASTERPLAN §7: default-deny inbound and forward.

flush ruleset

table inet filter {
    chain input {
        type filter hook input priority 0; policy {{ nftables_default_inbound }};

        # Allow established / related traffic
        ct state { established, related } accept

        # Allow loopback
        iifname "lo" accept

        # Allow ICMP (ping)
        ip  protocol icmp  accept
        ip6 nexthdr  icmpv6 accept

        # Allow SSH on configured port
        tcp dport {{ ssh_port }} ct state new accept

        # Log and drop everything else
        log prefix "[nft-drop] " drop
    }

    chain forward {
        type filter hook forward priority 0; policy {{ nftables_default_forward }};
    }

    chain output {
        type filter hook output priority 0; policy {{ nftables_default_outbound }};
    }
}
